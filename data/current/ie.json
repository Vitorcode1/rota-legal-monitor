      "date": "2024-09-02",
      "severity": "major",
      "sourceUrl": "https://enterprise.gov.ie/en/What-We-Do/Workplace-and-Skills/Employment-Permits/Employment-Permit-Eligibility/Highly-Skilled-Eligible-Occupations-List/",
      "summary": "Nova versão da Critical Skills Occupations List entrou em vigor com a aprovação de SI 444 de 2024. A lista foi reorganizada e atualizada para refletir as ocupações críticas e habilidades específicas elegíveis para o visto de trabalho.",
      "title": "Critical Skills Occupations List Atualizada"
    },
    {
      "affects": [
        "Todos os tipos de Employment Permits"
      ],
      "date": "2024-01-01",
      "severity": "major",
      "sourceUrl": "https://enterprise.gov.ie/en/What-We-Do/Workplace-and-Skills/Employment-Permits/Permit-Types/Permit-Types.html",
      "summary": "O Employment Permits Act 2024 permite nove diferentes tipos de Employment Permits. Esta lei atualizada regula todos os tipos de vistos de trabalho na Irlanda.",
      "title": "Employment Permits Act 2024"
    },
    {
      "affects": [
        "General Employment Permit",
        "Critical Skills Employment Permit",
        "Intra-Company Transfer Employment Permit",
        "Contract for Services Employment Permit",
        "Reactivation Employment Permit",
        "Sport and Cultural Employment Permit",
        "Internship Employment Permit"
      ],
      "date": "2014-10-01",
      "severity": "major",
      "sourceUrl": "https://enterprise.gov.ie/en/What-We-Do/Workplace-and-Skills/Employment-Permits/Fees/",
      "summary": "A partir de 1º de outubro de 2014, o Departamento não aceita mais pagamentos em papel de candidatos comerciais. Pagamento deve ser feito por transferência eletrônica de fundos. Candidatos individuais podem continuar com cheques em euros ou optar por transferência eletrônica.",
      "title": "Alteração nas modalidades de pagamento de taxas"
    }
