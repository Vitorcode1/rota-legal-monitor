# Chave da API da Anthropic. Obtenha em https://console.anthropic.com
# Necessaria para a extracao via LLM funcionar.
ANTHROPIC_API_KEY=sk-ant-...

# Modelo a ser usado. Padrao razoavel listado.
# Opcoes: claude-sonnet-4-5, claude-haiku-4-5
ANTHROPIC_MODEL=claude-sonnet-4-5

# Token do GitHub para abrir issues automatizadas em caso de mudanca relevante.
# Em GitHub Actions, usar o GITHUB_TOKEN automatico (nao precisa setar aqui).
# Para testes locais, criar token pessoal com permissao de issues.
GITHUB_TOKEN=ghp_...

# Modo de execucao. Padrao: production. Use development para logs verbosos.
NODE_ENV=production

# Timeout para fetch em milissegundos. Padrao 30000.
FETCH_TIMEOUT_MS=30000

# Rate limit em milissegundos por host. Padrao 2000.
RATE_LIMIT_MS=2000
